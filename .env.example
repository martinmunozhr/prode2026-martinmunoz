# ============================================================
# Plantilla de variables de entorno para el Prode Mundial 2026.
# Copiar a `.env` y completar los valores. NUNCA commitear `.env`.
# ============================================================

# ---- Supabase (cliente + servidor) ----
# Las publishable/anon keys son publicas por diseno (van al bundle del navegador).
# Sacar de Supabase Dashboard > Settings > API.
SUPABASE_URL="https://<project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

VITE_SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="<project-id>"

# ---- Server-only (NUNCA usar prefijo VITE_) ----
# En produccion (Cloudflare) tambien van seteadas con `wrangler secret put`.

# Service role key — bypassea RLS, requerida por todas las server actions admin.
# Supabase Dashboard > Settings > API > Reveal service_role
SUPABASE_SERVICE_ROLE_KEY=""

# API-Football (https://dashboard.api-football.com) — free tier 100 req/dia
API_FOOTBALL_KEY=""

# WC2026 API (https://api.wc2026api.com) — fuente alternativa
# Si queda vacia los endpoints WC2026 tiran error explicito; la app sigue funcionando.
WC2026_API_KEY=""
